# Secrets — chmod 600, gitignored. Split by tools/split_env.py.
# Add new secret-shaped vars here; non-secrets belong in config.env.
# Rules: KEY contains PASSWORD/SECRET/TOKEN/API_KEY/JWT/etc, OR value is
# a URI with embedded user:pass@host. Exceptions: *_CACHE_TTL, *_TIMEOUT,
# *_INTERVAL, *_VALIDITY*, *_ENABLED, *_URL/_BASE_URL/_HOSTNAME are NOT secrets.

# Regression fixture for the bug where the splitter moved compose-substituted
# variables out of .env into config.env, breaking `docker compose up`.
# When the matching compose.yaml references ${MY_VAR}, that var must STAY
# in .env regardless of whether it looks like a secret.
DOMAIN=example.com
AUTHELIA_HOSTNAME=auth.example.com
WEBAUTHN_DISPLAY_NAME=MyAuthelia
ANOTHER_SECRET_TOKEN=very-secret-value
