# Secrets — chmod 600, gitignored. Split by tools/split_env.py.
# Add new secret-shaped vars here; non-secrets belong in config.env.
# Rules: KEY contains PASSWORD/SECRET/TOKEN/API_KEY/JWT/etc, OR value is
# a URI with embedded user:pass@host. Exceptions: *_CACHE_TTL, *_TIMEOUT,
# *_INTERVAL, *_VALIDITY*, *_ENABLED, *_URL/_BASE_URL/_HOSTNAME are NOT secrets.

# Fixture for split_env extensions added after the 91b087d leak post-mortem:
#   - MASTER_KEY suffix routes to .env
#   - bare *_API suffix routes to .env
#   - commented-out KV lines route by classification
#   - ENABLE_*/DISABLE_*/PUBLIC_* are NOT secrets even with _API suffix
#   - *_CACHE_TTL_<suffix> stays non-secret

# Real secrets — should land in .env
MEILI_MASTER_KEY=9hkI0AHNj3SDxZThQBOMumaKivyADTmam3K1yyNXp0PEVrG
TMDB_API=2b8a5eabce2a76f5caf0d714fab0f3f1
HMAC_SECRET=abc123abc123abc123abc123
PASSWORD_SALT=somesaltvalue
WEBHOOK_SIGNATURE=deadbeefcafebabe
BEARER_TOKEN_VALUE=eyJhbGciOiJIUzI1NiJ9.foo.bar

# Commented secret should also land in .env (would otherwise leak)
# TORBOX_API_KEY=262efea7-a6f8-4a77-9b7d-babd6de13c76
