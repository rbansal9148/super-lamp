# Non-secret configuration. Safe to commit. Split by tools/split_env.py.
# Add new non-secret vars here; secrets belong in .env.

# Basic secrets vs config split.
ADDON_NAME="MyAddon"
PORT=3000
LOG_LEVEL=info
# A timeout setting — must NOT be treated as a secret despite the _CACHE_TTL suffix on a key with API_KEY in it.
RPDB_API_KEY_VALIDITY_CACHE_TTL=604800
BACKGROUND_RESOURCE_REQUEST_TIMEOUT=15000
