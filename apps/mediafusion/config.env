# ========================================================
#             CORE APPLICATION SETTINGS 
# ========================================================
HOST_URL=https://${MEDIAFUSION_HOSTNAME?}
POSTER_HOST_URL=https://${MEDIAFUSION_HOSTNAME}
METADATA_PRIMARY_SOURCE=tmdb
CONTACT_EMAIL="admin@example.com"
LOGGING_LEVEL=INFO

# ========================================================
#             DATABASE AND CACHE SETTINGS 
# ========================================================
REDIS_URL=redis://mediafusion_redis:6379
STARTUP_MIGRATE_ONLY=false
# SQLAlchemy pool budget per engine (pool_size + max_overflow)
DB_MAX_CONNECTIONS=50

# Gunicorn runtime tuning
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=20
GUNICORN_MAX_REQUESTS=10000
GUNICORN_MAX_REQUESTS_JITTER=5000

# ========================================================
#             EXTERNAL SERVICE SETTINGS 
# ========================================================
REQUESTS_PROXY_URL=http://gluetun:8080
FLARESOLVERR_URL=http://flaresolverr:8191

# ========================================================
#             PROWLARR SETTINGS 
# ========================================================
IS_SCRAP_FROM_PROWLARR=True
PROWLARR_URL=http://prowlarr:9696
PROWLARR_IMMEDIATE_MAX_PROCESS=30
PROWLARR_IMMEDIATE_MAX_PROCESS_TIME=30
PROWLARR_SEARCH_INTERVAL_HOUR=24
PROWLARR_FEED_SCRAPE_INTERVAL_HOUR=2
PROWLARR_LIVE_TITLE_SEARCH=false

# ========================================================
#             JACKETT SETTINGS 
# ========================================================
IS_SCRAP_FROM_JACKETT=False
JACKETT_URL=http://jackett:9117
JACKETT_IMMEDIATE_MAX_PROCESS=30
JACKETT_IMMEDIATE_MAX_PROCESS_TIME=30
JACKETT_SEARCH_INTERVAL_HOUR=24
JACKETT_FEED_SCRAPE_INTERVAL_HOUR=1
JACKETT_LIVE_TITLE_SEARCH=false

# ========================================================
#             ZILEAN SETTINGS 
# ========================================================
IS_SCRAP_FROM_ZILEAN=True
ZILEAN_SEARCH_INTERVAL_HOUR=1
ZILEAN_URL=http://zilean:8181

# ========================================================
#             TORRENTIO SETTINGS 
# ========================================================
IS_SCRAP_FROM_TORRENTIO=False  # Cloudflare-blocked from this network вҖ” returns 0 results but wastes a slot in live scrape
TORRENTIO_SEARCH_INTERVAL_DAYS=1
TORRENTIO_URL=https://torrentio.strem.fun

# Disable Public Usenet indexer live scrape вҖ” adds ~25-30s per request, only gives ~16 streams
# Set to True to re-enable; comment out for default (True).
IS_SCRAP_FROM_PUBLIC_USENET_INDEXERS=False

# ========================================================
#             MEDIAFUSION SETTINGS 
# ========================================================
IS_SCRAP_FROM_MEDIAFUSION=False  # external instance midnightignite.me returns 404 for many movies, adds 30s per request
MEDIAFUSION_SEARCH_INTERVAL_DAYS=1
MEDIAFUSION_URL=https://mediafusionfortheweebs.midnightignite.me

# ========================================================
#             BT4G SETTINGS 
# ========================================================
IS_SCRAP_FROM_BT4G=true
BT4G_URL=https://bt4gprx.com
BT4G_SEARCH_INTERVAL_HOUR=18
BT4G_SEARCH_TIMEOUT=30
BT4G_IMMEDIATE_MAX_PROCESS=30
BT4G_IMMEDIATE_MAX_PROCESS_TIME=30

# ========================================================
#             FEATURE TOGGLES
# ========================================================
IS_SCRAP_FROM_YTS=True
ENABLE_RATE_LIMIT=False
STORE_STREMTHRU_MAGNET_CACHE=True
SCRAPE_WITH_AKA_TITLES=False

# Route all queues (default/scrapy/import/priority) into one worker queue.
# Standard docker-compose uses this mode by default with one worker service.
# HA and K8s templates can set this to false for dedicated queue workers.
TASKIQ_SINGLE_WORKER_MODE="true"

# ========================================================
#             SCHEDULER SETTINGS 
# ========================================================

BACKGROUND_SEARCH_INTERVAL_HOURS=24
TAMILMV_SCHEDULER_CRONTAB="13 */8 * * *"
TAMIL_BLASTERS_SCHEDULER_CRONTAB="20 */8 * * *"
TAMILULTRA_SCHEDULER_CRONTAB="33 */8 * * *"

# Cache TTL bumps (defaults: 1800 / 900)
META_CACHE_TTL=3600
STREAM_RAW_REDIS_CACHE_TTL_SECONDS=3600

# Disable all background schedulers вҖ” stops background_search (every 3min), dmm_hashlist (hourly),
# formula_ext (30min), sport_video (20min), movies_tv_ext (hourly), and the regional Tamil scrapers.
# Live user-search path is unaffected.
DISABLE_ALL_SCHEDULER=true
