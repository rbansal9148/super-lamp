# Enable/disable in-process & redis caching (true/false)
CACHE_ENABLED=true

# TTL (ms) for interface cache (default 6 hours)
CACHE_TTL_MS=21600000

# Max in-memory interface cache entries
MAX_CACHE_ENTRIES=100

# Optional Redis URL for shared caching (comment out to disable Redis)
REDIS_URL=redis://iptv_redis:6379/0

# Enable verbose debug logging (true/false)
DEBUG_MODE=true
