# Gluetun VPN Configuration
# Provider wiki: https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers/mullvad

VPN_SERVICE_PROVIDER=mullvad
VPN_TYPE=wireguard
WIREGUARD_ADDRESSES="10.67.194.217/32"

# Server selection — pinned to Singapore (closest to Mumbai VPS, ~50-80ms)
# Mullvad has 0 India servers. Singapore is the lowest-latency option for South Asia.
# Alternatives: Hong Kong, Japan, UAE, Sweden. See: https://github.com/qdm12/gluetun-wiki/blob/main/setup/providers/mullvad.md
SERVER_COUNTRIES=Singapore
# SERVER_CITIES=

# Server list updater
UPDATER_PERIOD=24h
