# REDIS_URL=
REDIS_URL=redis://syncio_redis:6379
DEBUG=false
NEXT_PUBLIC_DEBUG=false
# Backend cookie naming uses __Host- prefix and Secure/SameSite=strict only when
# NODE_ENV=production; without this, frontend (built with prod) and backend
# (defaulting to dev) disagree on cookie name → session cookies appear set but
# the auth gate can't find them on followup requests → 401 after login.
NODE_ENV=production
DATABASE_URL=postgresql://syncio:syncio@syncio_postgres:5432/syncio

# User/Group IDs for Docker (optional - defaults to 1000:1000)
# Run 'id' command to get your UID and GID
UID=${PUID}
GID=${PGID}
