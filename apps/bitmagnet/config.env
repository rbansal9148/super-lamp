TMDB_ENABLED=true

# All other configuration options can be found here: https://bitmagnet.io/setup/configuration.html
# But it is not required to alter anything else. Once it is running you can use the following URLs to access BitMagnet:

# Internal URL: http://bitmagnet:3333 (e.g. AIOStreams' BUILTIN_BITMAGNET_URL and StremThru's STREMTHRU_INTEGRATION_BITMAGNET_BASE_URL)
# Database URI: postgresql://bitmagnet:bitmagnet@bitmagnet_postgres:5432/bitmagnet (StremThru's STREMTHRU_INTEGRATION_BITMAGNET_DATABASE_URI)
# Web UI: https://bitmagnet.${DOMAIN}

DHT_CRAWLER.SCALING_FACTOR=2
# Was 100 — lowered to slow DHT ingest from ~13k/h to ~2.6k/h so prune (200k/day) keeps pace
PROCESSOR_CONCURRENCY=10

LOG_FILE_ROTATOR_ENABLED=false

POSTGRES_HOST=bitmagnet_postgres
POSTGRES_DB=bitmagnet
POSTGRES_USER=bitmagnet

# INDEXER_CATEGORY_FILTER=2000-2999,5000-5999
BM_FILTER_CATEGORIES=2000,5000
