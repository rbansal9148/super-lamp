# -------------- DebriDav Web Interface --------------

# Port on the host to expose DebriDav’s web interface (internal port is always 8080)
DEBRIDAV_PORT=8888

# -------------- Miscellaneous --------------

# Skip caching local files smaller than this (in MB)
DEBRIDAV_CACHE_LOCAL_DEBRID_FILES_THRESHOLD_MB=10
